#!/usr/bin/env python3
import glob
import os
import re
import subprocess
import sys
from collections import defaultdict

JUST_DIR = "/usr/share/blossomos"
JUSTFILE = "/tmp/adjust"

group_re = re.compile(r'\[group\("(.+?)"\)\]')
recipe_re = re.compile(r"^([a-zA-Z0-9_\-]+)(.*):\s*$")
comment_re = re.compile(r"^#(?!!)(.*)$")

# colors
BLUE = "\033[1;34m"
CYAN = "\033[1;36m"
GREEN = "\033[1;32m"
YELLOW = "\033[1;33m"
DIM = "\033[2m"
BOLD = "\033[1m"
RESET = "\033[0m"


def setup_scripts(parts):
    dst = "/tmp/scripts"
    os.makedirs(dst, exist_ok=True)
    for path in parts:
        src = os.path.join(os.path.dirname(path), "scripts")
        if not os.path.isdir(src):
            continue
        for name in os.listdir(src):
            link = os.path.join(dst, name)
            target = os.path.join(src, name)
            if os.path.islink(link):
                os.unlink(link)
            if not os.path.exists(link):
                os.symlink(target, link)


def assemble():
    parts = sorted(glob.glob(f"{JUST_DIR}/**/*.just", recursive=True))
    setup_scripts(parts)
    with open(JUSTFILE, "w") as out:
        for path in parts:
            with open(path) as f:
                out.write(f.read())
            out.write("\n")
    return parts


def parse_all(parts):
    all_groups = defaultdict(list)
    for path in parts:
        default_group = os.path.splitext(os.path.basename(path))[0]
        current_group = default_group
        last_comment = ""

        with open(path) as f:
            for line in f:
                line = line.rstrip()

                g = group_re.search(line)
                if g:
                    current_group = g.group(1)
                    continue

                c = comment_re.search(line)
                if c:
                    last_comment = c.group(1).strip()
                    continue

                r = recipe_re.match(line)
                if r:
                    name = r.group(1)
                    params = r.group(2).strip()
                    all_groups[current_group].append(
                        {
                            "name": name,
                            "params": params,
                            "desc": last_comment,
                            "private": name.startswith("_"),
                        }
                    )
                    last_comment = ""

    return all_groups


def print_table(groups):
    print(f"{BLUE}{BOLD}adjust system commands{RESET}")
    print(f"{DIM}usage: adjust <namespace> <command> [args]{RESET}\n")

    for group, items in groups.items():
        print(f"{CYAN}{BOLD}{group}{RESET}")
        print(f"{DIM}{'-' * len(group)}{RESET}")
        print(f"{BOLD}{'Command':28} {'Params':20} Description{RESET}")

        for i in items:
            if i["private"] or i["name"] == "default":
                continue
            print(
                f"{GREEN}{i['name']:28}{RESET} "
                f"{YELLOW}{i['params'] or '':20}{RESET} "
                f"{i['desc'] or ''}"
            )

        print()


def parse_recipes(parts):
    recipes = defaultdict(set)
    for path in parts:
        namespace = os.path.splitext(os.path.basename(path))[0]
        with open(path) as f:
            for line in f:
                r = recipe_re.match(line.rstrip())
                if r:
                    recipes[namespace].add(r.group(1))
    return recipes


def run(args, parts, recipes):
    namespace = args[0]
    if namespace not in recipes:
        owners = sorted(n for n, names in recipes.items() if namespace in names)
        if owners:
            print(
                f"unknown command: {namespace}\n"
                f"did you mean: {BOLD}adjust {owners[0]} {namespace}{RESET}",
                file=sys.stderr,
            )
        else:
            print(
                f"unknown namespace: {namespace}\n"
                f"available: {', '.join(sorted(recipes))}",
                file=sys.stderr,
            )
        sys.exit(1)

    rest = args[1:]
    if not rest:
        ns_parts = [
            p for p in parts
            if os.path.splitext(os.path.basename(p))[0] == namespace
        ]
        print_table(parse_all(ns_parts))
        return
    if not rest[0].startswith("-") and rest[0] not in recipes[namespace]:
        print(f"unknown command in {namespace}: {rest[0]}", file=sys.stderr)
        sys.exit(1)
    result = subprocess.run(["just", "--justfile", JUSTFILE, *rest])
    sys.exit(result.returncode)


if __name__ == "__main__":
    parts = assemble()
    if len(sys.argv) == 1:
        print_table(parse_all(parts))
    else:
        run(sys.argv[1:], parts, parse_recipes(parts))
